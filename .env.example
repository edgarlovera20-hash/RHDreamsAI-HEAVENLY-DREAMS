# --- Backend ---
# Puerto del servidor API.
API_PORT=3001

# (Opcional) GEMINI_API_KEY: solo si quieres usar Gemini desde el frontend (legacy).
# Para uso normal, configura proveedores desde Settings → Proveedores IA.
GEMINI_API_KEY=

# (Opcional) URL pública de la app (para callbacks futuros).
APP_URL=http://localhost:3000
